# ── PDF ────────────────────────────────────────────────────────────────────────
# Filename of the PDF inside the data/ directory
PDF_FILENAME=product_catalogue.pdf

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Generation model (must be pulled via: ollama pull <model>)
GENERATION_MODEL=llama3.1:8b

# Embedding model (must be pulled via: ollama pull nomic-embed-text)
# If Ollama embedding fails, system falls back to sentence-transformers all-MiniLM-L6-v2
EMBEDDING_MODEL=nomic-embed-text

# ── OpenAI fallback (used when Ollama generation fails) ────────────────────────
OPENAI_API_KEY=open_ai_api_key
OPENAI_MODEL=gpt-4o-mini

# ── Retrieval tuning ───────────────────────────────────────────────────────────
TOP_K_VECTOR=15
TOP_K_BM25=15
TOP_K_FINAL=6

# Score spread below which disambiguation triggers (fraction of top score)
DISAMBIG_THRESHOLD=0.15

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_COLLECTION=catalogue_chunks

# ── Chunking ───────────────────────────────────────────────────────────────────
MAX_CHUNK_CHARS=2000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
